# ============================================================
# Jingga — Environment Variables
# ============================================================
# Copy this file to .env (apps/api/.env) for local dev.
# For production, set these in Railway (API) & Vercel (Web).
# ============================================================

# ---------- Supabase ----------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ---------- Stellar ----------
STELLAR_NETWORK=testnet
# STELLAR_NETWORK=mainnet          # uncomment for mainnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_FRIENDBOT_URL=https://friendbot.stellar.org

# ---------- Soroban Smart Contracts ----------
CONTRACT_ROYALTY_SPLIT=CARE27GIE5INY76J2RQOKCLBM7CFXBP4SIUDRCJDHE46MPI6XJP7CAR2
CONTRACT_LICENSE_MANAGER=CBIHU3DRV6U3UBMHVIAQQWB2KRCSY6VM3DXNB76ZSHEOCQJR6DFPR7C7
CONTRACT_DEPLOYER_PUBLIC_KEY=GDEB5U56S3WIT3IFIKWTQ2UZPWOLR3W22QHBEV3I4PHBFOHH2BUVYRJH

# ---------- IPFS / Pinata ----------
PINATA_API_KEY=your-pinata-api-key
PINATA_SECRET_KEY=your-pinata-secret-key
PINATA_GATEWAY_URL=your-gateway.mypinata.cloud

# ---------- Server ----------
PORT=3001                           # Railway overrides this automatically
CORS_ORIGIN=http://localhost:3000   # Set to Vercel URL in production

# ---------- JWT ----------
JWT_SECRET=change-this-in-production

# ============================================================
# RAILWAY (API backend)
# ============================================================
# 1. Create a new Railway project -> "Deploy from GitHub"
# 2. Select this repo -> set Root Directory to "apps/api"
# 3. Railway auto-detects Dockerfile - NO extra config needed
# 4. Add ALL env vars above EXCEPT PORT (Railway sets it)
# 5. Set CORS_ORIGIN to your Vercel frontend URL
#
#    Railway will build from apps/api/Dockerfile & auto-restart
#    on every push to the connected branch.

# ============================================================
# VERCEL (Web frontend)
# ============================================================
# These env vars must be set in Vercel dashboard:
NEXT_PUBLIC_API_URL=http://localhost:3001    # -> Railway URL in production
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_STELLAR_NETWORK=testnet
#
# Vercel setup:
# 1. Import repo -> Root Directory: "apps/web"
# 2. Framework: Next.js (auto-detected)
# 3. Install Command: pnpm install (auto-detected)
# 4. Build Command: next build (auto-detected)
# 5. Add the 4 NEXT_PUBLIC_* env vars above
#
#    Vercel auto-deploys on every push to the connected branch.
